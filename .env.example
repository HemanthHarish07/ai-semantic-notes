### Example environment variables (do NOT commit secrets)
# Fill these in before running in production.

# Gemini API key for summarization/tagging
GEMINI_API_KEY=

# Postgres DATABASE_URL (example: postgresql://user:password@postgres:5432/appdb)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/appdb

# JWT secret
SECRET_KEY=change_this_to_a_strong_secret

# Optional: choose embedding provider: 'hf' for local sentence-transformers or 'none'
EMBEDDING_PROVIDER=hf
